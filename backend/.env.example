# Copy to .env and fill in the values for local development.
# spring-dotenv automatically loads .env into Spring property sources.

# Firebase Admin SDK
FIREBASE_ADMINSDK_PATH=/path/to/firebase-adminsdk.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Twitter OAuth
TWITTER_CONSUMER_KEY=your-twitter-consumer-key
TWITTER_CONSUMER_SECRET=your-twitter-consumer-secret
